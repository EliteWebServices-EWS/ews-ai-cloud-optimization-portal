{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "index.ts",
    "api/**/*.ts",
    "engines/**/*.ts",
    "plugins/**/*.ts",
    "providers/**/*.ts",
    "orchestrator/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "src"]
}
